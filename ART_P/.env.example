# ============================================================
# ART_P 环境变量配置示例
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入你的实际配置值
# 3. config.py 会自动加载 .env 文件中的配置

# ---- AI 服务配置 ----

# DeepSeek API 密钥（必填）
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your-api-key-here

# API 基础地址
# 官方: https://api.deepseek.com
# 国内中转站: https://yunai.chat/v1
DEEPSEEK_BASE_URL=https://yunai.chat/v1

# 使用的模型名称
# deepseek-chat: 对话模型（推荐）
# deepseek-coder: 代码专用模型
DEEPSEEK_MODEL=deepseek-chat

# ---- 网络配置 ----

# HTTP 代理地址（国内访问外网需要代理时填写）
# 格式: http://127.0.0.1:7890 或 http://user:pass@proxy.com:8080
# 不需要代理时请留空或设为 none
HTTP_PROXY=

# HTTPS 代理地址（通常与 HTTP_PROXY 相同）
HTTPS_PROXY=

# 禁用代理的域名（逗号分隔，* 表示全部禁用）
NO_PROXY=*

# ---- 请求超时配置 ----

# 整体请求超时时间（秒）
# PDF 解析通常 60-120 秒
# 综述生成可能需要 120-180 秒
REQUEST_TIMEOUT=120

# TCP 连接建立超时（秒）
# 如果网络较慢，适当调大
CONNECT_TIMEOUT=30

# 请求失败最大重试次数
MAX_RETRIES=3

# 重试间隔时间（秒）
RETRY_DELAY=1.0

# ---- 应用配置 ----

# FastAPI 服务端口
# Java 后端通过此端口调用 Python 服务
APP_PORT=8000

# 服务监听地址
# 127.0.0.1: 仅本机访问
# 0.0.0.0: 允许外部访问
APP_HOST=127.0.0.1

# 调试模式
# true: 显示详细日志（开发环境）
# false: 简洁日志（生产环境）
DEBUG_MODE=false

# ---- PDF 解析配置 ----

# 解析 PDF 时提取的最多页数
# 学术论文前几页通常包含摘要，足以提取核心信息
PDF_MAX_PAGES=5

# 是否过滤页眉页脚（预留）
PDF_FILTER_HEADER_FOOTER=true

# ---- AI 生成参数 ----

# PDF 解析温度参数 (0.0-2.0)
# 较低值更确定性，较高值更有创意
# 信息提取建议用低值
PARSE_TEMPERATURE=0.3

# PDF 解析最大 Token 数
# 控制单篇解析输出的最大长度
PARSE_MAX_TOKENS=1000

# 综述生成温度参数
# 综述需要创造性综合，适用较高值
REVIEW_TEMPERATURE=0.7

# 综述生成最大 Token 数
# 综述大纲通常较长
REVIEW_MAX_TOKENS=4000

# ---- 日志配置 ----

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 控制台彩色输出
COLORED_LOG=true
