# ============================================
# ART 项目部署配置模板
# 使用方法: cp .env.example .env
# docker-compose 和 deploy.sh 会自动读取 .env
# ============================================

# === 服务端口 ===
ART_P_PORT=8000
ART_H_PORT=8080
ART_Q_PORT=5173

# === 数据库（云端 PostgreSQL）===
DB_URL=jdbc:postgresql://your-cloud-host:5432/art
DB_USERNAME=postgres
DB_PASSWORD=change-me

# === API 密钥 ===
DEEPSEEK_API_KEY=your-api-key-here

# === 部署行为开关（仅 deploy.sh 读取，不影响容器）===
TARGET_BRANCH=main
AUTO_PULL=false
CLEAN_IMAGES=false
BACKUP_DATA=false
ENABLE_HTTPS=false
SELECTED_SERVICES="art-p art-h art-q"
