# ============================================
# ART 项目部署配置模板
# 使用方法: cp .env.example .env
# docker-compose 和 deploy.sh 会自动读取 .env
# ============================================

# === 服务端口 ===
ART_P_PORT=8000
ART_H_PORT=8080
ART_Q_PORT=5173

# === 数据库 ===
# Docker 容器访问宿主机 PostgreSQL 使用 host.docker.internal
# 如果 PostgreSQL 在远程服务器，替换为实际 IP
DB_URL=jdbc:postgresql://host.docker.internal:5432/art
DB_USERNAME=postgres
DB_PASSWORD=change-me

# === AI 服务配置 ===
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://yunai.chat/v1
DEEPSEEK_MODEL=deepseek-chat

# === Embedding 配置 ===
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_BASE_URL=https://yunai.chat/v1
EMBEDDING_MODEL=text-embedding-3-small

# === 网络代理 ===
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=*

# === 请求超时 ===
REQUEST_TIMEOUT=120
CONNECT_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=1.0

# === 应用配置 ===
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG_MODE=false

# === PDF 解析 ===
PDF_MAX_PAGES=5
PDF_FILTER_HEADER_FOOTER=true

# === AI 生成参数 ===
PARSE_TEMPERATURE=0.3
PARSE_MAX_TOKENS=1000
REVIEW_TEMPERATURE=0.7
REVIEW_MAX_TOKENS=4000

# === 日志 ===
LOG_LEVEL=INFO
COLORED_LOG=true

# === 部署行为开关（仅 deploy.sh 读取，不影响容器）===
TARGET_BRANCH=main
AUTO_PULL=false
CLEAN_IMAGES=false
BACKUP_DATA=false
ENABLE_HTTPS=false
SELECTED_SERVICES="art-p art-h art-q"
